# ── ОБЯЗАТЕЛЬНЫЕ ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
OWNER_ID=your_telegram_user_id_here
GEMINI_KEY=your_gemini_api_key_here

# ── О ТЕБЕ И БИЗНЕСЕ (используется в промпте ИИ) ──────────────────────────
OWNER_NAME=Имя Фамилия
BUSINESS_NAME=Название Компании
BUSINESS_DESCRIPTION=Опиши своё дело в 1-2 предложениях. Например: Продаём оборудование для кафе и ресторанов. Работаем с 2015 года.

# ── ЯЗЫК ОТВЕТОВ ИИ ────────────────────────────────────────────────────────
AI_LANGUAGE=ru

# ── ГЛУБИНА ИСТОРИИ ДИАЛОГА (сколько прошлых сообщений помнит ИИ) ─────────
AI_HISTORY_DEPTH=10

# ── ТАЙМАУТ СЕССИИ В СЕКУНДАХ (3600 = 1 час) ──────────────────────────────
SESSION_TIMEOUT=3600

# ── НЕОБЯЗАТЕЛЬНЫЕ ────────────────────────────────────────────────────────────
SUPPORT_GROUP_ID=0
DATABASE_PATH=bot.db
LOG_LEVEL=INFO
